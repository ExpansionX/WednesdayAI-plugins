  103\\t      await index.build(sampleSkills);\\n   104\\t      expect(index.getSkill(\\\"weather\\\")?.description).toContain(\\\"weather\\\");\\n   105\\t    });\\n   106\\t\\n   107\\t    it(\\\"returns undefined for unknown skill\\\", async () => {\\n   108\\t      const index = new SkillIndex(mockBackend);\\n   109\\t      await index.build(sampleSkills);\\n   110\\t      expect(index.getSkill(\\\"nonexistent\\\")).toBeUndefined();\\n   111\\t    });\\n   112\\t  });\\n   113\\t\\n   114\\t  describe(\\\"dispose()\\\", () => {\\n   115\\t    it(\\\"clears index and releases memory\\\", async () => {\\n   116\\t      const index = new SkillIndex(mockBackend);\\n   117\\t      await index.build(sampleSkills);\\n   118\\t      index.dispose();\\n   119\\t      expect(index.size).toBe(0);\\n   120\\t    });\\n   121\\t  });\\n   122\\t});\\n   123\\t```\\n   124\\t\\n   125\\t## Change\\n   126\\t\\n   127\\t**File:** `extensions/skillweaver/src/skill-index.ts`\\n   128\\t**Anchor:** new file — create at this path\\n   129\\t**Before:** file does not exist\\n   130\\t**After:**\\n   131\\t```ts\\n   132\\timport type { EmbeddingBackend, SkillEntry, SearchResult, IndexedSkill } from \\\"./embedding/types.js\\\";\\n   133\\timport { createSubsystemLogger } from \\\"wednesdayai/plugin-sdk\\\";\\n   134\\t\\n   135\\tconst log = createSubsystemLogger(\\\"skillweaver/index\\\");\\n   136\\t\\n   137\\texport class SkillIndex {\\n   138\\t  private backend: EmbeddingBackend;\\n   139\\t  private skills = new Map<string, IndexedSkill>();\\n   140\\t  private index: Awaited<ReturnType<typeof this.createHnsw>> | null = null;\\n   141\\t\\n   142\\t  constructor(backend: EmbeddingBackend) {\\n   143\\t    this.backend = backend;\\n   144\\t  }\\n   145\\t\\n   146\\t  get size(): number {\\n   147\\t    return this.skills.size;\\n   148\\t  }\\n   149\\t\\n   150\\t  async build(entries: SkillEntry[]): Promise<void> {\\n   151\\t    this.skills.clear();\\n   152\\t    this.index = null;\\n   153\\t    if (entries.length === 0) return;\\n   154\\t\\n   155\\t    for (const entry of entries) {\\n   156\\t      this.skills.set(entry.name, { ...entry, vector: new Float32Array(0) });\\n   157\\t    }\\n   158\\t\\n   159\\t    const names = [...this.skills.keys()];\\n   160\\t    const documents = names.map((name) => {\\n   161\\t      const skill = this.skills.get(name)!;\\n   162\\t      return `${skill.name}: ${skill.description}`;\\n   163\\t    });\\n   164\\t\\n   165\\t    const vectors = await this.backend.embed(documents);\\n   166\\t    for (let i = 0; i < names.length; i++) {\\n   167\\t      const existing = this.skills.get(names[i]);\\n   168\\t      if (existing) existing.vector = vectors[i];\\n   169\\t    }\\n   170\\t\\n   171\\t    if (vectors.length === 0) return;\\n   172\\t\\n   173\\t    const { HierarchicalNSW } = await import(\\\"hnswlib-node\\\");\\n   174\\t    const index = new HierarchicalNSW(\\\"cosine\\\", this.backend.dimensions);\\n   175\\t    index.initIndex(vectors.length);\\n   176\\t    index.setEf(400);\\n   177\\t\\n   178\\t    const ids = Array.from({ length: vectors.length }, (_, i) => i);\\n   179\\t    ids.forEach((id, i) => index.addPoint(vectors[i], id));\\n   180\\t    this.index = index;\\n   181\\t\\n   182\\t    log.info(`index built: ${this.skills.size} skills, ${this.backend.dimensions}d`);\\n   183\\t  }\\n   184\\t\\n   185\\t  async search(query: string, topK: number): Promise<SearchResult[]> {\\n   186\\t    if (!this.index || this.skills.size === 0) return [];\\n   187\\t\\n   188\\t    const queryVector = await this.backend.embedSingle(query);\\n   189\\t    const names = [...this.skills.keys()];\\n   190\\t    const k = Math.min(topK, this.skills.size);\\n   191\\t    const result = this.index.searchKnn(queryVector, k, undefined);\\n   192\\t\\n   193\\t    const hits = typeof result === \\\"object\\\" && result !== null\\n   194\\t      ? (result as { distances: Float64Array; neighbors: Float64Array })\\n   195\\t      : this.parseLegacyResult(result, k);\\n   196\\t\\n   197\\t    const results: SearchResult[] = [];\\n   198\\t    for (let i = 0; i < Math.min(k, hits.neighbors.length); i++) {\\n   199\\t      const idx = hits.neighbors[i];\\n   200\\t      const distance = hits.distances[i];\\n   201\\t      if (idx < names.length) {\\n   202\\t        const name = names[idx];\\n   203\\t        const skill = this.skills.get(name)!;\\n   204\\t        results.push({\\n   205\\t          name: skill.name,\\n   206\\t          description: skill.description,\\n   207\\t          location: skill.location,\\n   208\\t          source: skill.source,\\n   209\\t          score: 1 - distance,\\n   210\\t        });\\n   211\\t      }\\n   212\\t    }\\n   213\\t    return results;\\n   214\\t  }\\n   215\\t\\n   216\\t  getSkill(name: string): SkillEntry | undefined {\\n   217\\t    const skill = this.skills.get(name);\\n   218\\t    if (!skill) return undefined;\\n   219\\t    const { vector: _, ...entry } = skill;\\n   220\\t    return entry;\\n   221\\t  }\\n   222\\t\\n   223\\t  dispose(): void {\\n   224\\t    this.index = null;\\n   225\\t    this.skills.clear();\\n   226\\t  }\\n   227\\t\\n   228\\t  private parseLegacyResult(result: unknown, k: number): { distances: Float64Array; neighbors: Float64Array } {\\n   229\\t    if (result && typeof result === \\\"object\\\" && \\\"distances\\\" in result && \\\"neighbors\\\" in result) {\\n   230\\t      const r = result as Record<string, unknown>;\\n   231\\t      return {\\n   232\\t        distances: r.distances as Float64Array,\\n   233\\t        neighbors: r.neighbors as Float64Array,\\n   234\\t      };\\n   235\\t    }\\n   236\\t    throw new Error(\\\"hnswlib returned unrecognized search result shape\\\");\\n   237\\t  }\\n   238\\t\\n   239\\t  private async createHnsw() {\\n   240\\t    const { HierarchicalNSW } = await import(\\\"hnswlib-node\\\");\\n   241\\t    return new HierarchicalNSW(\\\"cosine\\\", this.backend.dimensions);\\n   242\\t  }\\n   243\\t}\\n   244\\t```\\n   245\\t\\n   246\\t## Allowed moves\\n   247\\t\\n   248\\tCreate exactly `extensions/skillweaver/src/skill-index.ts` and its test. Add `hnswlib-node` to dependencies in package.json ONLY if the test requires the real module (prefer mocking @import level). No other files.\\n   249\\t\\n   250\\t## STOP triggers\\n   251\\t\\n   252\\t- `search()` returns results when `this.index` is null\\n   253\\t- hnswlib-node `HierarchicalNSW` constructor signature doesn't match expectations — check actual package API\\n   254\\t- Duplicate names silently double-count — dedup by name must be verified\\n   255\\t- `embed()` is called with document strings that don't include skill description\\n   256\\t\\n   257\\t## Done when\\n   258\\t\\n   259\\t`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx vitest run src/skill-index.test.ts\\\" bash ~/.claude/wai/scripts/task-gate.sh plugin-skillweaver 008` exits 0     1\\t---\\n     2\\tid: \\\"009\\\"\\n     3\\tphase: 3\\n     4\\ttitle: Add debounced fs.watch rebuild to SkillIndex for live skill file changes\\n     5\\tstatus: ready\\n     6\\tdepends_on: [\\\"008\\\"]\\n     7\\tparallel: false\\n     8\\tconflicts_with: []\\n     9\\tfiles:\\n    10\\t  - extensions/skillweaver/src/skill-index.ts\\n    11\\tirreversible: false\\n    12\\tscope_test: \\\"extensions/skillweaver/src/skill-index.test.ts\\\"\\n    13\\tallowed_change: edit\\n    14\\tcovers_criteria: [SC1]\\n    15\\t---\\n    16\\t## Failing test (write first)\\n    17\\t\\n    18\\tAdd these tests to `extensions/skillweaver/src/skill-index.test.ts`:\\n    19\\t\\n    20\\t```ts\\n    21\\t// ==== Add to existing describe(\\\"SkillIndex\\\", () => { ... }) block ====\\n    22\\t\\n    23\\t  describe(\\\"watch() / rebuild\\\", () => {\\n    24\\t    it(\\\"watch() starts a file watcher\\\", async