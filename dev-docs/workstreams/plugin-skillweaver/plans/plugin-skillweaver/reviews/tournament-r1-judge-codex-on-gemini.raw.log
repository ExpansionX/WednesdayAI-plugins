": [\\\"imessage\\\", \\\"read-write\\\", \\\"github\\\"],\\n   254\\t      \\\"expectedSubtasks\\\": 3\\n   255\\t    },\\n   256\\t    {\\n   257\\t      \\\"id\\\": \\\"M09\\\",\\n   258\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   259\\t      \\\"query\\\": \\\"Browse a documentation site, extract API endpoints, and update a Postman collection\\\",\\n   260\\t      \\\"expectedSkills\\\": [\\\"browser\\\", \\\"web-fetch\\\", \\\"read-write\\\"],\\n   261\\t      \\\"expectedSubtasks\\\": 3\\n   262\\t    },\\n   263\\t    {\\n   264\\t      \\\"id\\\": \\\"M10\\\",\\n   265\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   266\\t      \\\"query\\\": \\\"Check the weather, calculate travel time, and send a summary via WhatsApp\\\",\\n   267\\t      \\\"expectedSkills\\\": [\\\"weather\\\", \\\"math\\\", \\\"whatsapp\\\"],\\n   268\\t      \\\"expectedSubtasks\\\": 3\\n   269\\t    },\\n   270\\t    {\\n   271\\t      \\\"id\\\": \\\"M11\\\",\\n   272\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   273\\t      \\\"query\\\": \\\"Query a database, transform the results, and schedule a daily export cron job\\\",\\n   274\\t      \\\"expectedSkills\\\": [\\\"database\\\", \\\"read-write\\\", \\\"cron\\\"],\\n   275\\t      \\\"expectedSubtasks\\\": 3\\n   276\\t    },\\n   277\\t    {\\n   278\\t      \\\"id\\\": \\\"M12\\\",\\n   279\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   280\\t      \\\"query\\\": \\\"Download a video, extract audio, transcribe it, and save the transcript\\\",\\n   281\\t      \\\"expectedSkills\\\": [\\\"web-fetch\\\", \\\"media\\\", \\\"tts\\\", \\\"read-write\\\"],\\n   282\\t      \\\"expectedSubtasks\\\": 3\\n   283\\t    },\\n   284\\t    {\\n   285\\t      \\\"id\\\": \\\"M13\\\",\\n   286\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   287\\t      \\\"query\\\": \\\"Find duplicate files, report sizes, and archive them\\\",\\n   288\\t      \\\"expectedSkills\\\": [\\\"exec\\\", \\\"read-write\\\", \\\"exec\\\"],\\n   289\\t      \\\"expectedSubtasks\\\": 3\\n   290\\t    },\\n   291\\t    {\\n   292\\t      \\\"id\\\": \\\"M14\\\",\\n   293\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   294\\t      \\\"query\\\": \\\"Read a blog post, extract key quotes, search for related papers, and compile a reading list\\\",\\n   295\\t      \\\"expectedSkills\\\": [\\\"web-fetch\\\", \\\"web-search\\\", \\\"read-write\\\"],\\n   296\\t      \\\"expectedSubtasks\\\": 3\\n   297\\t    },\\n   298\\t    {\\n   299\\t      \\\"id\\\": \\\"M15\\\",\\n   300\\t      \\\"difficulty\\\": \\\"medium\\\",\\n   301\\t      \\\"query\\\": \\\"Export Slack channel history, analyze sentiment, and generate a report chart\\\",\\n   302\\t      \\\"expectedSkills\\\": [\\\"slack\\\", \\\"read-write\\\", \\\"image-gen\\\"],\\n   303\\t      \\\"expectedSubtasks\\\": 3\\n   304\\t    },\\n   305\\t    {\\n   306\\t      \\\"id\\\": \\\"H01\\\",\\n   307\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   308\\t      \\\"query\\\": \\\"Collect data from 3 different APIs, merge and clean the datasets, run statistical analysis, visualize trends, and publish results to a GitHub wiki page\\\",\\n   309\\t      \\\"expectedSkills\\\": [\\\"web-fetch\\\", \\\"read-write\\\", \\\"math\\\", \\\"image-gen\\\", \\\"github\\\"],\\n   310\\t      \\\"expectedSubtasks\\\": 5\\n   311\\t    },\\n   312\\t    {\\n   313\\t      \\\"id\\\": \\\"H02\\\",\\n   314\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   315\\t      \\\"query\\\": \\\"Clone a repo, check out a feature branch, run all linters, fix auto-fixable issues, create a PR, and notify the team on Slack and Discord\\\",\\n   316\\t      \\\"expectedSkills\\\": [\\\"github\\\", \\\"exec\\\", \\\"github\\\", \\\"slack\\\", \\\"discord\\\"],\\n   317\\t      \\\"expectedSubtasks\\\": 4\\n   318\\t    },\\n   319\\t    {\\n   320\\t      \\\"id\\\": \\\"H03\\\",\\n   321\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   322\\t      \\\"query\\\": \\\"Download a dataset, train a simple model, evaluate it, save the model and metrics, and send an email with the results\\\",\\n   323\\t      \\\"expectedSkills\\\": [\\\"web-fetch\\\", \\\"exec\\\", \\\"read-write\\\", \\\"email\\\"],\\n   324\\t      \\\"expectedSubtasks\\\": 5\\n   325\\t    },\\n   326\\t    {\\n   327\\t      \\\"id\\\": \\\"H04\\\",\\n   328\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   329\\t      \\\"query\\\": \\\"Check all connected channels, collect unread message counts, aggregate by platform, format a dashboard image, and post it to Telegram\\\",\\n   330\\t      \\\"expectedSkills\\\": [\\\"telegram\\\", \\\"discord\\\", \\\"slack\\\", \\\"image-gen\\\", \\\"telegram\\\"],\\n   331\\t      \\\"expectedSubtasks\\\": 4\\n   332\\t    },\\n   333\\t    {\\n   334\\t      \\\"id\\\": \\\"H05\\\",\\n   335\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   336\\t      \\\"query\\\": \\\"Read a technical paper PDF, extract methodology section, reproduce the experiment setup in code, run the benchmark, compare results with the paper's claims, and write a replication report\\\",\\n   337\\t      \\\"expectedSkills\\\": [\\\"pdf\\\", \\\"read-write\\\", \\\"exec\\\", \\\"math\\\", \\\"read-write\\\"],\\n   338\\t      \\\"expectedSubtasks\\\": 5\\n   339\\t    },\\n   340\\t    {\\n   341\\t      \\\"id\\\": \\\"H06\\\",\\n   342\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   343\\t      \\\"query\\\": \\\"Query the database for user activity, find top users, check GitHub contribution graphs, cross-reference with Slack messages, and generate a comprehensive activity report\\\",\\n   344\\t      \\\"expectedSkills\\\": [\\\"database\\\", \\\"github\\\", \\\"slack\\\", \\\"read-write\\\"],\\n   345\\t      \\\"expectedSubtasks\\\": 4\\n   346\\t    },\\n   347\\t    {\\n   348\\t      \\\"id\\\": \\\"H07\\\",\\n   349\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   350\\t      \\\"query\\\": \\\"Monitor running Docker containers, collect resource metrics, identify anomalies, restart unhealthy containers, log the incident, and notify via email and Telegram\\\",\\n   351\\t      \\\"expectedSkills\\\": [\\\"docker\\\", \\\"exec\\\", \\\"read-write\\\", \\\"email\\\", \\\"telegram\\\"],\\n   352\\t      \\\"expectedSubtasks\\\": 4\\n   353\\t    },\\n   354\\t    {\\n   355\\t      \\\"id\\\": \\\"H08\\\",\\n   356\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   357\\t      \\\"query\\\": \\\"Set up a new project: init git repo, create directory structure, write config files, add CI pipeline, install dependencies, scaffold tests, and push to GitHub with a Slack announcement\\\",\\n   358\\t      \\\"expectedSkills\\\": [\\\"github\\\", \\\"read-write\\\", \\\"exec\\\", \\\"slack\\\"],\\n   359\\t      \\\"expectedSubtasks\\\": 5\\n   360\\t    },\\n   361\\t    {\\n   362\\t      \\\"id\\\": \\\"H09\\\",\\n   363\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   364\\t      \\\"query\\\": \\\"Scrape a competitor website, extract pricing data, compare with our pricing, generate a summary table, and save as PDF for review\\\",\\n   365\\t      \\\"expectedSkills\\\": [\\\"web-fetch\\\", \\\"browser\\\", \\\"read-write\\\", \\\"pdf\\\"],\\n   366\\t      \\\"expectedSubtasks\\\": 4\\n   367\\t    },\\n   368\\t    {\\n   369\\t      \\\"id\\\": \\\"H10\\\",\\n   370\\t      \\\"difficulty\\\": \\\"hard\\\",\\n   371\\t      \\\"query\\\": \\\"Ingest iMessage history, identify contacts with most messages, filter by date range, compute reply time distributions, generate charts, and export as a markdown report\\\",\\n   372\\t      \\\"expectedSkills\\\": [\\\"imessage\\\", \\\"read-write\\\", \\\"math\\\", \\\"image-gen\\\", \\\"read-write\\\"],\\n   373\\t      \\\"expectedSubtasks\\\": 5\\n   374\\t    }\\n   375\\t  ]\\n   376\\t}\\n   377\\t```\\n   378\\t\\n   379\\t## Change\\n   380\\t\\n   381\\t**File:** `extensions/skillweaver/src/__tests__/benchmark.ts`\\n   382\\t**Anchor:** new file — create at this path\\n   383\\t**Before:** file does not exist\\n   384\\t**After:**\\n   385\\t```ts\\n   386\\timport type { SearchResult, HintEntry } from \\\"../embedding/types.js\\\";\\n   387\\t\\n   388\\tinterface BenchmarkQuery {\\n   389\\t  id: string;\\n   390\\t  difficulty: \\\"easy\\\" | \\\"medium\\\" | \\\"hard\\\";\\n   391\\t  query: string;\\n   392\\t  expectedSkills: string[];\\n   393\\t  expectedSubtasks: number;\\n   394\\t}\\n   395\\t\\n   396\\tinterface BenchmarkResult {\\n   397\\t  id: string;\\n   398\\t  difficulty: string;\\n   399\\t  query: string;\\n   400\\t  catR10: boolean;\\n   401\\t  catR1: boolean;\\n   402\\t  daExact: boolean;\\n   403\\t  daPlusMinus1: boolean;\\n   404\\t  latencyMs: number;\\n   405\\t  subTaskCount: number;\\n   406\\t  retrievedCount: number;\\n   407\\t  pass: number;\\n   408\\t}\\n   409\\t\\n   410\\tinterface BenchmarkSummary {\\n   411\\t  totalQueries: number;\\n   412\\t  catR10Rate: number;\\n   413\\t  catR1Rate: number;\\n   414\\t  daExactRate: number;\\n   415\\t  daPlusMinus1Rate: number;\\n   416\\t  avgLatencyMs: number;\\n   417\\t  byDifficulty: Record<string, Omit<BenchmarkSummary, \\\"byDifficulty\\\" | \\\"totalQueries\\\">>;\\n   418\\t}\\n   419\\t\\n   420\\tfunction computeCatR(retrieved: SearchResult[], expected: string[], k: number): boolean {\\n   421\\t  const topK = retrieved.slice(0, k).map((s) => s.name);\\n   422\\t  return expected.some((skill) => topK.includes(skill));\\n   423\\t}\\n   424\\t\\n   425\\tfunction computeDA(actualSubTasks: number, expectedSubTasks: number): { exact: boolean; plusMinus1: boolean } {\\n   426\\t  return {\\n   427\\t    exact: actualSubTasks === expectedSubTasks,\\n   428\\t    plusMinus1: Math.abs(actualSubTasks - expectedSubTasks) <= 1,\\n   429\\t  };\\n   430\\t}\\n   431\\t\\n   432\\texport async function runBenchmark(opts: {\\n   433\\t  decomposer: { decompose: (query: string, hints?: HintEntry[]) => Promise<{ subTasks: string[]; pass: number }> };\\n   434\\t  retriever: { retrieve: (subTasks: string[]) => Promise<SearchResult[]> };\\n   435\\t  queries: BenchmarkQuery[];\\n   436\\t  name?: string;\\n   437\\t}): Promise<{ results: BenchmarkResult[]; summary: BenchmarkSummary }> {\\n   438\\t  const results: BenchmarkResult[] = [];\\n   439\\t  let totalLatency = 0;\\n   440\\t\\n   441\\t  for (const q of opts.queries) {\\n   442\\t    const start = Date.now();\\n   443\\t\\n   444\\t    const pass1Result = await opts.decomposer.decompose(q.query);\\n   445\\t    const retrieved = await opts.retriever.retrieve(pass1Result.subTasks);\\n   446\\t    const latencyMs = Date.now() - start;\\n   447\\t    totalLatency += latencyMs;\\n   448\\t\\n   449\\t    const da = computeDA(pass1Result.subTasks.length, q.expectedSubtasks);\\n   450\\t\\n   451\\t    results.push({\\n   452\\t      id: q.id,\\n   453\\t      difficulty: q.difficulty,\\n   454\\t      query: q.query,\\n   455\\t      catR10: computeCatR(retrieved, q.expectedSkills, 10),\\n   456\\t      catR1: computeCatR(retrieved, q.expectedSkills, 1),\\n   457\\t      daExact: da.exact,\\n   458\\t      daPlusMinus1: da.plusMinus1,\\n   459\\t      latencyMs,\\n   460\\t      subTaskCount: pass1Result.subTasks.length,\\n   461\\t      retrievedCount: retrieved.length,\\n   462\\t      pass: pass1Result.pass,\\n   463\\t    });\\n   464\\t  }\\n   465\\t\\n   466\\t  const computeRates = (subset: BenchmarkResult[]) => {\\n   467\\t    const n = subset.length;\\n   468\\t    if (n === 0) return { catR10Rate: 0, catR1Rate: 0, daExactRate: 0, daPlusMinus1Rate: 0, avgLatencyMs: 0 };\\n   469\\t    return {\\n   470\\t      catR10Rate: subset.filter((r) => r.catR10).length / n,\\n   471\\t      catR1Rate: subset.filter((r) => r.catR1).length / n,\\n   472\\t      daExactRate: subset.filter((r) => r.daExact).length / n,\\n   473\\t      daPlusMinus1Rate: subset.filter((r) => r.daPlusMinus1).length / n,\\n   474\\t      avgLatencyMs: subset.reduce((s, r) => s + r.latencyMs, 0) / n,\\n   475\\t    };\\n   476\\t  };\\n   477\\t\\n   478\\t  const byDifficulty: Record<string, Omit<BenchmarkSummary, \\\"byDifficulty\\\" | \\\"totalQueries\\\">> = {};\\n   479\\t  for (const diff of [\\\"easy\\\", \\\"medium\\\", \\\"hard\\\"]) {\\n   480\\t    byDifficulty[diff] = computeRates(results.filter((r) => r.difficulty === diff));\\n   481\\t  }\\n   482\\t\\n   483\\t  return {\\n   484\\t    results,\\n   485\\t    summary: {\\n   486\\t      totalQueries: results.length,\\n   487\\t      ...computeRates(results),\\n   488\\t      byDifficulty,\\n   489\\t    },\\n   490\\t  };\\n   491\\t}\\n   492\\t```\\n   493\\t\\n   494\\t## Allowed moves\\n   495\\t\\n   496\\tCreate exactly the benchmark file, the fixtures JSON, and add them to `files:`. No other changes. The benchmark is run manually (`npx tsx src/__tests__/benchmark.ts`) — it is not a vitest test. It requires a real decomposer and retriever (or mocks configured for the specific benchmark fixture).\\n   497\\t\\n   498\\t## STOP triggers\\n   499\\t\\n   500\\t- `expectedSkills` references a skill name not in WednesdayAI's bundled skill list (verify against the actual skill names)\\n   501\\t- CatR calculation is inverted (should be: expected ∩ retrieved, not retrieved ∩ expected)\\n   502\\t\\n   503\\t## Manual verification (record in decisions-ledger)\\n   504\\t\\n   505\\tRun `npx tsx src/__tests__/benchmark.ts` with mocks or real components. Verify: `summary.catR10Rate >= 0.65` and `summary.daExactRate >= 0.60` from the output. Record actual rates in decisions-ledger.\\n   506\\t\\n   507\\t## Done when\\n   508\\t\\n   509\\t`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx tsx src/__tests__/benchmark.ts\\\" bash ~/.claude/wai/scripts/task-gate.sh plugin-skillweaver 017` exits 0     1\\t---\\n     2\\tid: \\\"018\\\"\\n     3\\tphase: 7\\n     4\\ttitle: Create integration tests — hook registration, cache boundary proof, slash command survival, sub-agent propagation, error resilience\\n     5\\tstatus: ready\\n     6\\tdepends_on: [\\\"016\\\"]\\n     7\\tparallel: false\\n     8\\tconflicts_with: []\\n     9\\tfiles:\\n    10\\t  - extensions/skillweaver/src/__tests__/integration.test.ts\\n    11\\tirreversible: false\\n    12\\tscope_test: \\\"extensions/skillweaver/src/__tests__/integration.test.ts\\\"\\n    13\\tallowed_change: create\\n    14\\tcovers_criteria: [SC3, SC4, SC5]\\n    15\\tcovers_tests: [TS1, TS2, TS3, TS4, TS5, TS6, TS7, TS8, TS9]\\n    16\\t---\\n    17\\t## Failing test (write first)\\n    18\\t\\n    19\\tCreate `extensions/skillweaver/src/__tests__/integration.test.ts`:\\n    20\\t\\n    21\\t```ts\\n    22\\timport { describe, it, expect, vi, beforeEach } from \\\"vitest\\\";\\n    23\\timport type { OpenClawPluginApi } from \\\"wednesdayai/plugin-sdk\\\";\\n    24\\t\\n    25\\tconst mockLogger = { info: vi.fn(), warn: vi.fn(), error: vi.fn(), debug: vi.fn() };\\n    26\\t\\n    27\\tfunction createMockApi(overrides: Partial<OpenClawPluginApi> = {}): OpenClawPluginApi {\\n    28\\t  return {\\n    29\\t    pluginConfig: {},\\n    30\\t    config: {\\n    31\\t      agents: { defaults: { systemPrompt: { sections: { skills: \\\"names\\\" } } } },\\n    32\\t    },\\n    33\\t    logger: mockLogger,\\n    34\\t    on: vi.fn(),\\n    35\\t    registerTool: vi.fn(),\\n    36\\t    ...overrides,\\n    37\\t  } as unknown as OpenClawPluginApi;\\n    38\\t}\\n    39\\t\\n    40\\tlet plugin: { id: string; register: (api: OpenClawPluginApi) => void };\\n    41\\t\\n    42\\tdescribe(\\\"integration\\\", () => {\\n    43\\t  beforeAll(async () => {\\n    44\\t    const mod = await import(\\\"../../index.js\\\");\\n    45\\t    plugin = mod.default ?? mod;\\n    46\\t  });\\n    47\\t\\n    48\\t  beforeEach(() => {\\n    49\\t    vi.clearAllMocks();\\n    50\\t  });\\n    51\\t\\n    52\\t  describe(\\\"hook registration\\\", () => {\\n    53\\t    it(\\\"registers context.collect hook\\\", () => {\\n    54\\t      const api = createMockApi();\\n    55\\t      plugin.register(api);\\n    56\\t      expect(api.on).toHaveBeenCalledWith(\\\"context.collect\\\", expect.any(Function));\\n    57\\t    });\\n    58\\t\\n    59\\t    it(\\\"returns a function from context.collect handler\\\", () => {\\n    60\\t      const api = createMockApi();\\n    61\\t      plugin.register(api);\\n    62\\t      const call = (api.on as ReturnType<typeof vi.fn>).mock.calls.find(\\n    63\\t        (c: [string, Function]) => c[0] === \\\"context.collect\\\",\\n    64\\t      );\\n    65\\t      expect(call).toBeDefined();\\n    66\\t      expect(typeof call[1]).toBe(\\\"function\\\");\\n    67\\t    });\\n    68\\t  });\\n    69\\t\\n    70\\t  describe(\\\"cache boundary proof\\\", () => {\\n    71\\t    it(\\\"returns prependContext (conversation injection), NOT systemPrompt\\\", async () => {\\n    72\\t      const api = createMockApi();\\n    73\\t      plugin.register(api);\\n    74\\t      const handler = (api.on as ReturnType<typeof vi.fn>).mock.calls.find(\\n    75\\t        (c: [string, Function]) => c[0] === \\\"context.collect\\\",\\n    76\\t      )[1];\\n    77\\t\\n    78\\t      const result = await handler({ cleanUserMessage: { text: \\\"hi\\\" } });\\n    79\\t      expect(result).toBeDefined();\\n    80\\t      if (result && Object.keys(result).length > 0) {\\n    81\\t        expect((result as Record<string, unknown>).appendedSystemPrompt).toBeUndefined();\\n    82\\t        expect((result as Record<string, unknown>).systemPrompt).toBeUndefined();\\n    83\\t      }\\n    84\\t    });\\n    85\\t  });\\n    86\\t\\n    87\\t  describe(\\\"slash commands\\\", () => {\\n    88\\t    it(\\\"plugin does not interfere with slash command resolution\\\", () => {\\n    89\\t      const api = createMockApi();\\n    90\\t      plugin.register(api);\\n    91\\t      expect(api.on).toHaveBeenCalledTimes(1);\\n    92\\t      expect((api.on as ReturnType<typeof vi.fn>)).not.toHaveBeenCalledWith(\\\"before_tool_call\\\", expect.anything());\\n    93\\t    });\\n    94\\t  });\\n    95\\t\\n    96\\t  describe(\\\"sub-agent propagation\\\", () => {\\n    97\\t    it(\\\"skips routing for sub-agent events\\\", async () => {\\n    98\\t      const api = createMockApi();\\n    99\\t      plugin.register(api);\\n   100\\t      const handler = (api.on as ReturnType<typeof vi.fn>).mock.calls.find(\\n   101\\t        (c: [string, Function]) => c[0] === \\\"context.collect\\\",\\n   102\\t      )[1];\\n   103\\t\\n   104\\t      const result = await handler({\\n   105\\t        cleanUserMessage: { text: \\\"a long enough query to normally trigger routing\\\" },\\n   106\\t        envelope: { isSubAgent: true },\\n   107\\t      });\\n   108\\t\\n   109\\t      expect(result).toEqual({});\\n   110\\t    });\\n   111\\t  });\\n   112\\t\\n   113\\t  describe(\\\"error resilience\\\", () => {\\n   114\\t    it(\\\"returns empty for short query\\\", async () => {\\n   115\\t      const api = createMockApi();\\n   116\\t      plugin.register(api);\\n   117\\t      const handler = (api.on as ReturnType<typeof vi.fn>).mock.calls.find(\\n   118\\t        (c: [string, Function]) => c[0] === \\\"context.collect\\\",\\n   119\\t      )[1];\\n   120\\t\\n   121\\t      const result = await handler({ cleanUserMessage: { text: \\\"hi\\\" } });\\n   122\\t      expect(result).toEqual({});\\n   123\\t    });\\n   124\\t\\n   125\\t    it(\\\"returns empty for sub-agent events\\\", async () => {\\n   126\\t      const api = createMockApi();\\n   127\\t      plugin.register(api);\\n   128\\t      const handler = (api.on as ReturnType<typeof vi.fn>).mock.calls.find(\\n   129\\t        (c: [string, Function]) => c[0] === \\\"context.collect\\\",\\n   130\\t      )[1];\\n   131\\t\\n   132\\t      const result = await handler({\\n   133\\t        cleanUserMessage: { text: \\\"long enough query text to pass min query length check\\\" },\\n   134\\t        envelope: { isSubAgent: true },\\n   135\\t      });\\n   136\\t\\n   137\\t      expect(result).toEqual({});\\n   138\\t    });\\n   139\\t\\n   140\\t    it(\\\"returns empty when disabled\\\", async () => {\\n   141\\t      const api = createMockApi({ pluginConfig: { enabled: false } });\\n   142\\t      plugin.register(api);\\n   143\\t      expect(api.on).not.toHaveBeenCalled();\\n   144\\t    });\\n   145\\t  });\\n   146\\t\\n   147\\t  describe(\\\"plugin identity\\\", () => {\\n   148\\t    it(\\\"has id 'skillweaver'\\\", () => {\\n   149\\t      expect(plugin.id).toBe(\\\"skillweaver\\\");\\n   150\\t    });\\n   151\\t\\n   152\\t    it(\\\"has configSchema with all required sections\\\", () => {\\n   153\\t      expect(plugin.configSchema).toBeDefined();\\n   154\\t      const schema = plugin.configSchema as Record<string, unknown>;\\n   155\\t      const props = schema.properties as Record<string, unknown>;\\n   156\\t      expect(props).toHaveProperty(\\\"enabled\\\");\\n   157\\t      expect(props).toHaveProperty(\\\"decomposer\\\");\\n   158\\t      expect(props).toHaveProperty(\\\"embedding\\\");\\n   159\\t      expect(props).toHaveProperty(\\\"retrieval\\\");\\n   160\\t      expect(props).toHaveProperty(\\\"sad\\\");\\n   161\\t    });\\n   162\\t  });\\n   163\\t});\\n   164\\t```\\n   165\\t\\n   166\\t## Change\\n   167\\t\\n   168\\tCreate exactly `extensions/skillweaver/src/__tests__/integration.test.ts` with the content above. No other files.\\n   169\\t\\n   170\\t## Allowed moves\\n   171\\t\\n   172\\tCreate exactly the integration test file. No other files. The test imports from `../../index.js` (relative from `src/__tests__/` to the extension root).\\n   173\\t\\n   174\\t## STOP triggers\\n   175\\t\\n   176\\t- Handler returns `prependContext` for sub-agent events (must return `{}`)\\n   177\\t- Handler returns `prependContext` for messages shorter than `minQueryLength`\\n   178\\t- Plugin registers hooks other than `c