7\\t```ts\\n    98\\timport type { OpenClawPluginApi } from \\\"wednesdayai/plugin-sdk\\\";\\n    99\\timport manifest from \\\"./openclaw.plugin.json\\\" with { type: \\\"json\\\" };\\n   100\\timport { resolveConfig, validateConfig, checkSkillsMode } from \\\"./src/config.js\\\";\\n   101\\t\\n   102\\tconst plugin = {\\n   103\\t  id: manifest.id,\\n   104\\t  name: manifest.name,\\n   105\\t  description: manifest.description,\\n   106\\t  configSchema: manifest.configSchema,\\n   107\\t\\n   108\\t  register(api: OpenClawPluginApi) {\\n   109\\t    const rawConfig = (api.pluginConfig ?? {}) as Record<string, unknown>;\\n   110\\t    const config = resolveConfig(rawConfig);\\n   111\\t    validateConfig(config);\\n   112\\t\\n   113\\t    if (!config.enabled) {\\n   114\\t      api.logger.info(\\\"skillweaver: disabled via config\\\");\\n   115\\t      return;\\n   116\\t    }\\n   117\\t\\n   118\\t    const skillsMode = checkSkillsMode(api.config);\\n   119\\t    if (skillsMode === \\\"default\\\" || skillsMode === \\\"compact\\\") {\\n   120\\t      api.logger.warn(\\n   121\\t        `skillweaver: detected skills mode \\\"${skillsMode}\\\". ` +\\n   122\\t          `For optimal context savings, set ` +\\n   123\\t          `agents.defaults.systemPrompt.sections.skills to \\\"names\\\" in your openclaw config. ` +\\n   124\\t          `With \\\"default\\\" mode, full skill descriptions still appear in the system prompt ` +\\n   125\\t          `alongside SkillWeaver's selective injection.`,\\n   126\\t      );\\n   127\\t    }\\n   128\\t\\n   129\\t    api.on(\\\"context.collect\\\", async (_event) => {\\n   130\\t      return {};\\n   131\\t    });\\n   132\\t  },\\n   133\\t};\\n   134\\t\\n   135\\texport default plugin;\\n   136\\t```\\n   137\\t**After:**\\n   138\\t```ts\\n   139\\timport type { OpenClawPluginApi } from \\\"wednesdayai/plugin-sdk\\\";\\n   140\\timport manifest from \\\"./openclaw.plugin.json\\\" with { type: \\\"json\\\" };\\n   141\\timport { resolveConfig, validateConfig, checkSkillsMode } from \\\"./src/config.js\\\";\\n   142\\timport { SkillIndex } from \\\"./src/skill-index.js\\\";\\n   143\\timport { LocalEmbedding } from \\\"./src/embedding/local.js\\\";\\n   144\\timport { CloudEmbedding } from \\\"./src/embedding/cloud.js\\\";\\n   145\\timport { CustomEmbedding } from \\\"./src/embedding/custom.js\\\";\\n   146\\timport type { EmbeddingBackend, SkillEntry } from \\\"./src/embedding/types.js\\\";\\n   147\\timport { Decomposer } from \\\"./src/decomposer.js\\\";\\n   148\\timport { createRetriever } from \\\"./src/retriever.js\\\";\\n   149\\timport { createCollectHandler } from \\\"./src/handler.js\\\";\\n   150\\t\\n   151\\tfunction resolveBackend(config: ReturnType<typeof resolveConfig>): EmbeddingBackend {\\n   152\\t  switch (config.embedding.backend) {\\n   153\\t    case \\\"local\\\":\\n   154\\t      return new LocalEmbedding(config.embedding.model);\\n   155\\t    case \\\"cloud\\\":\\n   156\\t      return new CloudEmbedding({\\n   157\\t        apiKey: config.embedding.apiKey,\\n   158\\t        model: config.embedding.cloudModel,\\n   159\\t      });\\n   160\\t    case \\\"custom\\\":\\n   161\\t      return new CustomEmbedding({\\n   162\\t        endpoint: config.embedding.endpoint,\\n   163\\t        apiKey: config.embedding.apiKey,\\n   164\\t      });\\n   165\\t  }\\n   166\\t}\\n   167\\t\\n   168\\tfunction collectSkillPaths(config: unknown): string[] {\\n   169\\t  const skillsCfg = (config as Record<string, unknown> | undefined)?.skills as\\n   170\\t    | { load?: { extraDirs?: string[]; paths?: string[] } }\\n   171\\t    | undefined;\\n   172\\t  return skillsCfg?.load?.extraDirs ?? skillsCfg?.load?.paths ?? [];\\n   173\\t}\\n   174\\t\\n   175\\tfunction isSkillEntry(entry: unknown): entry is { name: string; description: string; filePath: string; sourceInfo: string } {\\n   176\\t  return (\\n   177\\t    typeof entry === \\\"object\\\" &&\\n   178\\t    entry !== null &&\\n   179\\t    \\\"name\\\" in entry &&\\n   180\\t    \\\"description\\\" in entry &&\\n   181\\t    \\\"filePath\\\" in entry\\n   182\\t  );\\n   183\\t}\\n   184\\t\\n   185\\tasync function discoverSkills(_config: unknown): Promise<SkillEntry[]> {\\n   186\\t  return [];\\n   187\\t}\\n   188\\t\\n   189\\tconst plugin = {\\n   190\\t  id: manifest.id,\\n   191\\t  name: manifest.name,\\n   192\\t  description: manifest.description,\\n   193\\t  configSchema: manifest.configSchema,\\n   194\\t\\n   195\\t  register(api: OpenClawPluginApi) {\\n   196\\t    const rawConfig = (api.pluginConfig ?? {}) as Record<string, unknown>;\\n   197\\t    const config = resolveConfig(rawConfig);\\n   198\\t    validateConfig(config);\\n   199\\t\\n   200\\t    if (!config.enabled) {\\n   201\\t      api.logger.info(\\\"skillweaver: disabled via config\\\");\\n   202\\t      return;\\n   203\\t    }\\n   204\\t\\n   205\\t    const skillsMode = checkSkillsMode(api.config);\\n   206\\t    if (skillsMode === \\\"default\\\" || skillsMode === \\\"compact\\\") {\\n   207\\t      api.logger.warn(\\n   208\\t        `skillweaver: detected skills mode \\\"${skillsMode}\\\". ` +\\n   209\\t          `For optimal context savings, set ` +\\n   210\\t          `agents.defaults.systemPrompt.sections.skills to \\\"names\\\" in your openclaw config. ` +\\n   211\\t          `With \\\"default\\\" mode, full skill descriptions still appear in the system prompt ` +\\n   212\\t          `alongside SkillWeaver's selective injection.`,\\n   213\\t      );\\n   214\\t    }\\n   215\\t\\n   216\\t    const backend = resolveBackend(config);\\n   217\\t    const index = new SkillIndex(backend);\\n   218\\t\\n   219\\t    const decomposer = new Decomposer({\\n   220\\t      provider: config.decomposer.provider,\\n   221\\t      model: config.decomposer.model,\\n   222\\t      apiKey: config.decomposer.apiKey,\\n   223\\t      baseUrl: config.decomposer.baseUrl,\\n   224\\t      temperature: config.decomposer.temperature,\\n   225\\t      maxTokens: config.decomposer.maxTokens,\\n   226\\t    });\\n   227\\t\\n   228\\t    const retriever = createRetriever(index, {\\n   229\\t      topK: config.retrieval.topK,\\n   230\\t      hintSize: config.retrieval.hintSize,\\n   231\\t    });\\n   232\\t\\n   233\\t    const handler = createCollectHandler({\\n   234\\t      decomposer,\\n   235\\t      retriever,\\n   236\\t      sadEnabled: config.sad.enabled,\\n   237\\t      minQueryLength: config.retrieval.minQueryLength,\\n   238\\t      decomposerModel: config.decomposer.model,\\n   239\\t    });\\n   240\\t\\n   241\\t    api.on(\\\"context.collect\\\", handler);\\n   242\\t\\n   243\\t    discoverSkills(api.config).then((skills) => {\\n   244\\t      index.build(skills).catch((err) => {\\n   245\\t        api.logger.warn(\\\"skillweaver: initial index build failed\\\", { error: String(err) });\\n   246\\t      });\\n   247\\t    });\\n   248\\t\\n   249\\t    api.logger.info(\\\"skillweaver: registered\\\");\\n   250\\t  },\\n   251\\t};\\n   252\\t\\n   253\\texport default plugin;\\n   254\\t```\\n   255\\t\\n   256\\t## Allowed moves\\n   257\\t\\n   258\\tOnly edit `extensions/skillweaver/index.ts` (the complete replacement above) and replace the test file. Import path `\\\"./embedding/types.js\\\"` must use `.js` extension (ESM). The `discoverSkills` stub returns `[]` — actual skill discovery is not in scope for this task (it requires integration with the WednesdayAI skill loading system which is not available in the test environment).\\n   259\\t\\n   260\\t## STOP triggers\\n   261\\t\\n   262\\t- Any uncaught exception in `register()` — must not throw\\n   263\\t- `api.on` registered before config validation\\n   264\\t- Leaked API keys in log messages\\n   265\\t\\n   266\\t## Done when\\n   267\\t\\n   268\\t`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx vites