pts: CloudEmbeddingOptions = {}) {\n   153\t    this.apiKey = opts.apiKey ?? process.env.OPENAI_API_KEY ?? null;\n   154\t    this.model = opts.model ?? DEFAULT_MODEL;\n   155\t    this.endpoint = opts.endpoint ?? DEFAULT_ENDPOINT;\n   156\t  }\n   157\t\n   158\t  async embed(texts: string[]): Promise<Float32Array[]> {\n   159\t    if (this.disposed) throw new Error(\"CloudEmbedding: already disposed\");\n   160\t    const body = JSON.stringify({\n   161\t      model: this.model,\n   162\t      input: texts,\n   163\t      encoding_format: \"float\",\n   164\t    });\n   165\t\n   166\t    const headers: Record<string, string> = { \"Content-Type\": \"application/json\" };\n   167\t    if (this.apiKey) headers.Authorization = `Bearer ${this.apiKey}`;\n   168\t\n   169\t    const response = await fetch(this.endpoint, { method: \"POST\", headers, body });\n   170\t    if (!response.ok) {\n   171\t      throw new Error(`CloudEmbedding: request failed ${response.status}: ${await response.text()}`);\n   172\t    }\n   173\t\n   174\t    const json = await response.json() as { data: Array<{ embedding: number[]; index: number }> };\n   175\t    return json.data\n   176\t      .sort((a, b) => a.index - b.index)\n   177\t      .map((item) => new Float32Array(item.embedding));\n   178\t  }\n   179\t\n   180\t  async embedSingle(text: string): Promise<Float32Array> {\n   181\t    const results = await this.embed([text]);\n   182\t    return results[0];\n   183\t  }\n   184\t\n   185\t  dispose(): void {\n   186\t    this.disposed = true;\n   187\t  }\n   188\t}\n   189\t```\n   190\t\n   191\t## Allowed moves\n   192\t\n   193\tCreate exactly `extensions/skillweaver/src/embedding/cloud.ts` and its test. No other files.\n   194\t\n   195\t## STOP triggers\n   196\t\n   197\t- API key leaked to console/log in implementation\n   198\t- Request body does not include `encoding_format: \"float\"` (required for Float32Array)\n   199\t- Results not sorted by index (OpenAI returns para