144\\t    maxIterations: 1,\\n   145\\t  },\\n   146\\t};\\n   147\\t\\n   148\\tconst VALID_BACKENDS = new Set([\\\"local\\\", \\\"cloud\\\", \\\"custom\\\"]);\\n   149\\tconst VALID_PROVIDERS = new Set([\\\"openrouter\\\", \\\"openai\\\", \\\"anthropic\\\", \\\"openai-compatible\\\"]);\\n   150\\t\\n   151\\texport function resolveConfig(raw: Record<string, unknown>): SkillWeaverConfig {\\n   152\\t  const decomposer = { ...DEFAULTS.decomposer, ...(raw.decomposer as Partial<SkillWeaverConfig[\\\"decomposer\\\"]> ?? {}) };\\n   153\\t  const embedding = { ...DEFAULTS.embedding, ...(raw.embedding as Partial<SkillWeaverConfig[\\\"embedding\\\"]> ?? {}) };\\n   154\\t  const retrieval = { ...DEFAULTS.retrieval, ...(raw.retrieval as Partial<SkillWeaverConfig[\\\"retrieval\\\"]> ?? {}) };\\n   155\\t  const sad = { ...DEFAULTS.sad, ...(raw.sad as Partial<SkillWeaverConfig[\\\"sad\\\"]> ?? {}) };\\n   156\\t  return {\\n   157\\t    ...DEFAULTS,\\n   158\\t    enabled: raw.enabled !== undefined ? Boolean(raw.enabled) : DEFAULTS.enabled,\\n   159\\t    decomposer,\\n   160\\t    embedding,\\n   161\\t    retrieval,\\n   162\\t    sad,\\n   163\\t  };\\n   164\\t}\\n   165\\t\\n   166\\texport function validateConfig(config: SkillWeaverConfig): void {\\n   167\\t  if (!VALID_PROVIDERS.has(config.decomposer.provider)) {\\n   168\\t    throw new Error(`Invalid decomposer provider: ${config.decomposer.provider}`);\\n   169\\t  }\\n   170\\t  if (!VALID_BACKENDS.has(config.embedding.backend)) {\\n   171\\t    throw new Error(`Invalid embedding backend: ${config.embedding.backend}`);\\n   172\\t  }\\n   173\\t  if (config.retrieval.topK < 1 || config.retrieval.topK > 10) {\\n   174\\t    throw new Error(`topK must be 1-10, got ${config.retrieval.topK}`);\\n   175\\t  }\\n   176\\t  if (config.sad.maxIterations < 1 || config.sad.maxIterations > 5) {\\n   177\\t    throw new Error(`maxIterations must be 1-5, got ${config.sad.maxIterations}`);\\n   178\\t  }\\n   179\\t}\\n   180\\t\\n   181\\ttype SkillsMode = \\\"default\\\" | \\\"compact\\\" | \\\"names\\\" | \\\"off\\\";\\n   182\\t\\n   183\\texport function checkSkillsMode(coreConfig: Record<string, unknown> | undefined): SkillsMode {\\n   184\\t  const skills = (coreConfig as Record<string, unknown> | undefined)\\n   185\\t    ?.agents as Record<string, unknown> | undefined;\\n   186\\t  const defaults = skills?.defaults as Record<string, unknown> | undefined;\\n   187\\t  const sysPrompt = defaults?.systemPrompt as Record<string, unknown> | undefined;\\n   188\\t  const sections = sysPrompt?.sections as Record<string, unknown> | undefined;\\n   189\\t  const mode = sections?.skills as string | undefined;\\n   190\\t  if (mode === \\\"compact\\\" || mode === \\\"names\\\" || mode === \\\"off\\\") return mode;\\n   191\\t  return \\\"default\\\";\\n   192\\t}\\n   193\\t```\\n   194\\t\\n   195\\t## Allowed moves\\n   196\\t\\n   197\\tCreate exactly `extensions/skillweaver/src/config.ts` and `extensions/skillweaver/src/config.test.ts`. No other files.\\n   198\\t\\n   199\\t## STOP triggers\\n   200\\t\\n   201\\t- `extensions/skillweaver/src/` directory missing (task 001 not completed)\\n   202\\t- Any test expects a different default value than what DEFAULTS produces\\n   203\\t- `resolveConfig` returns shapes that don't match `SkillWeaverConfig` type\\n   204\\t\\n   205\\t## Done when\\n   206\\t\\n   207\\t`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx vitest run src/config.test.ts\\\" bash ~/.claude/wai/scripts/task-gate.sh plugin-skillweaver 002` exits 0     1\\t---\\n     2\\tid: \\\"003\\\"\\n     3\\tphase: 1\\n     4\\ttitle: Create plugin entry point with config warning for suboptimal skills mode\\n     5\\tstatus: ready\\n     6\\tdepends_on: [\\\"002\\\"]\\n     7\\tparallel: false\\n     8\\tconflicts_with: []\\n     9\\tfiles:\\n    10\\t  - extensions/skillweaver/index.ts\\n    11\\tirre