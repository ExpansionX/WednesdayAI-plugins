spose: Function } };\n    59\tlet LocalEmbedding: { new (...a: unknown[]): { id: string; dimensions: number; dispose: Function } };\n    60\tlet CloudEmbedding: { new (...a: unknown[]): { id: string; dimensions: number; dispose: Function } };\n    61\tlet CustomEmbedding: { new (...a: unknown[]): { id: string; dimensions: number; dispose: Function } };\n    62\t\n    63\tdescribe(\"lifecycle\", () => {\n    64\t  beforeAll(async () => {\n    65\t    SkillIndex = (await import(\"./skill-index.js\")).SkillIndex;\n    66\t    Decomposer = (await import(\"./decomposer.js\")).Decomposer;\n    67\t    LocalEmbedding = (await import(\"./embedding/local.js\")).LocalEmbedding;\n    68\t    CloudEmbedding = (await import(\"./embedding/cloud.js\")).CloudEmbedding;\n    69\t    CustomEmbedding = (await import(\"./embedding/custom.js\")).CustomEmbedding;\n    70\t  });\n    71\t\n    72\t  it(\"SkillIndex.dispose() clears skills and index\", async () => {\n    73\t    const index = new SkillIndex(mockBackend);\n    74\t    await index.build([\n    75\t      { name: \"test\", description: \"desc\", location: \"/x\", source: \"bundled\" },\n    76\t    ]);\n    77\t    expect(index.size).toBeGreaterThan(0);\n    78\t    index.dispose();\n    79\t    expect(index.size).toBe(0);\n    80\t  });\n    81\t\n    82\t  it(\"Decomposer.dispose() prevents further calls\", () => {\n    83\t    const d = new Decomposer({ provider: \"openrouter\", model: \"test\", apiKey: \"k\" });\n    84\t    d.dispose();\n    85\t    expect(() => d.dispose()).not.toThrow(); // idempotent\n    86\t  });\n    87\t\n    88\t  it(\"embedding backends support idempotent dispose\", () => {\n    89\t    const local = new LocalEmbedding();\n    90\t    const cloud = new CloudEmbedding();\n    91\t    const custom = new CustomEmbedding({ endpoint: \"http://localhost:8080/v1/embeddings\" });\n    92\t\n    93\t    expect(() => local.dispose()).not.toThrow();\n    94\t    expect(() => local.dispose()).not.toThrow(); 