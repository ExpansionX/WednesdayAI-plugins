er() does not throw with a mock api\\\", () => {\\n    65\\t    const api = createMockApi();\\n    66\\t    expect(() => plugin.register(api)).not.toThrow();\\n    67\\t  });\\n    68\\t\\n    69\\t  it(\\\"logs a warning when skills mode is default (suboptimal)\\\", () => {\\n    70\\t    const api = createMockApi({\\n    71\\t      config: {\\n    72\\t        agents: { defaults: { systemPrompt: { sections: { skills: \\\"default\\\" } } } },\\n    73\\t      } as never,\\n    74\\t    });\\n    75\\t    plugin.register(api);\\n    76\\t    expect(mockLogger.warn).toHaveBeenCalledWith(\\n    77\\t      expect.stringContaining(\\\"skillweaver\\\"),\\n    78\\t    );\\n    79\\t  });\\n    80\\t\\n    81\\t  it(\\\"does NOT warn when skills mode is names\\\", () => {\\n    82\\t    const api = createMockApi({\\n    83\\t      config: {\\n    84\\t        agents: { defaults: { systemPrompt: { sections: { skills: \\\"names\\\" } } } },\\n    85\\t      } as never,\\n    86\\t    });\\n    87\\t    plugin.register(api);\\n    88\\t    expect(mockLogger.warn).not.toHaveBeenCalledWith(\\n    89\\t      expect.stringContaining(\\\"skillweaver\\\"),\\n    90\\t    );\\n    91\\t  });\\n    92\\t\\n    93\\t  it(\\\"registers a context.collect hook\\\", () => {\\n    94\\t    const api = createMockApi();\\n    95\\t    plugin.register(api);\\n    96\\t    expect(api.on).toHaveBeenCalledWith(\\\"context.collect\\\", expect.any(Function));\\n    97\\t  });\\n    98\\t});\\n    99\\t```\\n   100\\t\\n   101\\t## Change\\n   102\\t\\n   103\\t**File:** `extensions/skillweaver/index.ts`\\n   104\\t**Anchor:** new file — create at this path\\n   105\\t**Before:** file does not exist\\n   106\\t**After:**\\n   107\\t```ts\\n   108\\timport type { OpenClawPluginApi } from \\\"wednesdayai/plugin-sdk\\\";\\n   109\\timport manifest from \\\"./openclaw.plugin.json\\\" with { type: \\\"json\\\" };\\n   110\\timport { resolveConfig, validateConfig, checkSkillsMode } from \\\"./src/config