se tests to `extensions/skillweaver/src/handler.test.ts`:\\n    20\\t\\n    21\\t```ts\\n    22\\t  // ==== Add to existing describe(\\\"createCollectHandler\\\", () => { ... }) block ====\\n    23\\t\\n    24\\t  it(\\\"handles decomposer timeout gracefully\\\", async () => {\\n    25\\t    const timeoutError = new Error(\\\"timeout\\\");\\n    26\\t    mockDecomposer.decompose.mockImplementationOnce(async () => {\\n    27\\t      await new Promise(() => {}); // never resolves\\n    28\\t    });\\n    29\\t\\n    30\\t    const handler = createCollectHandler({\\n    31\\t      decomposer: mockDecomposer as never,\\n    32\\t      retriever: mockRetriever as never,\\n    33\\t      sadEnabled: false,\\n    34\\t      minQueryLength: 20,\\n    35\\t      decomposerModel: \\\"test\\\",\\n    36\\t    });\\n    37\\t\\n    38\\t    const result = Promise.resolve(handler(baseEvent));\\n    39\\t    const timeout = new Promise((resolve) => setTimeout(() => resolve({}), 100));\\n    40\\t    const winner = await Promise.race([result, timeout]);\\n    41\\t\\n    42\\t    expect(winner).toEqual({});\\n    43\\t  });\\n    44\\t\\n    45\\t  it(\\\"handles retriever search failure gracefully\\\", async () => {\\n    46\\t    mockDecomposer.decompose.mockResolvedValueOnce({\\n    47\\t      subTasks: [\\\"task1\\\"], hints: [], pass: 1,\\n    48\\t    });\\n    49\\t    mockRetriever.retrieve.mockRejectedValueOnce(new Error(\\\"index corrupt\\\"));\\n    50\\t    mockFormatSkillContext.mockReturnValueOnce({});\\n    51\\t\\n    52\\t    const handler = createCollectHandler({\\n    53\\t      decomposer: mockDecomposer as never,\\n    54\\t      retriever: mockRetriever as never,\\n    55\\t      sadEnabled: false,\\n    56\\t      minQueryLength: 20,\\n    57\\t      decomposerModel: \\\"test\\\",\\n    58\\t    });\\n    59\\t\\n    60\\t    const result = await handler(baseEvent);\\n    61\\t    expect(result).toEqual({});\\n    62\\t  });\\n    63\\t\\n    64\\t  it(\\\"handles null/undefined cleanUserMessage\\\", async () => {\\n    65\\t    const handler = createCollectHandler({\\n    66\\t      decomposer: mockDecomposer as never,\\n    67\\t      retriever: mockRetriever as never,\\n    68\\t      sadEnabled: true,\\n    69\\t      minQueryLength: 20,\\n    70\\t      decomposerModel: \\\"test\\\",\\n    71\\t    });\\n    72\\t\\n    73\\t    const result = await handler({ ...baseEvent, cleanUserMessage: undefined as never });\\n    74\\t    expect(result).toEqual({});\\n    75\\t  });\\n    76\\t\\n    77\\t  it(\\\"does not crash on malformed envelope\\\", async () => {\\n    78\\t    const handler = createCollectHandler({\\n    79\\t      decomposer: mockDecomposer as never,\\n    80\\t      retriever: mockRetriever as never,\\n    81\\t      sadEnabled: true,\\n    82\\t      minQueryLength: 20,\\n    83\\t      decomposerModel: \\\"test\\\",\\n    84\\t    });\\n    85\\t\\n    86\\t    const result = await handler({ ...baseEvent, envelope: null as never });\\n    87\\t    expect(result).toEqual({});\\n    88\\t  });\\n    89\\t```\\n    90\\t\\n    91\\tAlso create `extensions/skillweaver/src/decomposer.timeout.test.ts`:\\n    92\\t\\n    93\\t```ts\\n    94\\timport { describe, it, expect, vi } from \\\"vitest\\\";\\n    95\\t\\n    96\\tconst mockFetchRaw = vi.fn();\\n    97\\t\\n    98\\tlet Decomposer: { new (...args: unknown[]): { decompose: Function; dispose: Function } };\\n    99\\t\\n   100\\tdescribe(\\\"Decomposer timeout handling\\\", () => {\\n   101\\t  beforeAll(async () => {\\n   102\\t    const mod = await import(\\\"./decomposer.js\\\");\\n   103\\t    Decomposer = mod.Decomposer;\\n   104\\t  });\\n   105\\t\\n   106\\t  it(\\\"returns empty result when fetch takes too long\\\", async () => {\\n   107\\t    mockFetchRaw.mockImplementationOnce(() => new Promise(() => {}));\\n   108\\t\\n   109\\t    const decomposer = new Decomposer({\\n   110\\t      fetchRaw: mockFetchRaw,\\n   111\\t      provider: \\\"openrouter\\\",\\n   112\\t      model: \\\"test\\\",\\n   113\\t      apiKey: \\\"sk-test\\\",\\n   114\\t    });\\n   115\\t\\n   116\\t    const resultPromise = decomposer.decompose(\\\"query\\\");\\n   117\\t    const earlyResult = await Promise.race([resultPromise, Promise.resolve({ subTasks: [], hints: [], pass: 1 })]);\\n   118\\t\\n   119\\t    expect(earlyResult.subTasks).toEqual([]);\\n   120\\t  });\\n   121\\t\\n   122\\t  it(\\\"returns empty result on HTTP 500\\\", async () => {\\n   123\\t    mockFetchRaw.mockResolvedValueOnce({\\n   124\\t      ok: false,\\n   125\\t      status: 500,\\n   126\\t      text: async () => \\\"Internal Server Error\\\",\\n   127\\t    });\\n   128\\t\\n   129\\t    const decomposer = new Decomposer({\\n   130\\t      fetchRaw: mockFetchRaw,\\n   131\\t      provider: \\\"openrouter\\\",\\n   132\\t      model: \\\"test\\\",\\n   133\\t      apiKey: \\\"sk-test\\\",\\n   134\\t    });\\n   135\\t\\n   136\\t    const result = await decomposer.decompose(\\\"query\\\");\\n   137\\t    expect(result.subTasks).toEqual([]);\\n   138\\t  });\\n   139\\t\\n   140\\t  it(\\\"returns empty result on HTTP 429 (rate limited)\\\", async () => {\\n   141\\t    mockFetchRaw.mockResolvedValueOnce({\\n   142\\t      ok: false,\\n   143\\t      status: 429,\\n   144\\t      text: async () => \\\"Rate limit exceeded\\\",\\n   145\\t    });\\n   146\\t\\n   147\\t    const decomposer = new Decomposer({\\n   148\\t      fetchRaw: mockFetchRaw,\\n   149\\t      provider: \\\"openrouter\\\",\\n   150\\t      model: \\\"test\\\",\\n   151\\t      apiKey: \\\"sk-test\\\",\\n   152\\t    });\\n   153\\t\\n   154\\t    const result = await decomposer.decompose(\\\"query\\\");\\n   155\\t    expect(result.subTasks).toEqual([]);\\n   156\\t  });\\n   157\\t});\\n   158\\t```\\n   159\\t\\n   160\\t## Change\\n   161\\t\\n   162\\t**File:** `extensions/skillweaver/src/handler.ts`\\n   163\\t**Anchor:** `createCollectHandler` — improve error guards around `cleanUserMessage` and `envelope`\\n   164\\t**Before:** (in the handler body, lines 2-4 after opening the async function)\\n   165\\t```ts\\n   166\\t    const text = event.cleanUserMessage?.text ?? \\\"\\\";\\n   167\\t    if (text.length < opts.minQueryLength) return {};\\n   168\\t\\n   169\\t    if (event.envelope?.[\\\"isSubAgent\\\"]) return {};\\n   170\\t```\\n   171\\t**After:**\\n   172\\t```ts\\n   173\\t    const text = event.cleanUserMessage?.text ?? \\\"\\\";\\n   174\\t    if (!text || text.length < opts.minQueryLength) return {};\\n   175\\t\\n   176\\t    if (event.envelope && typeof event.envelope === \\\"object\\\" && (event.envelope as Record<string, unknown>)[\\\"isSubAgent\\\"]) return {};\\n   177\\t```\\n   178\\t\\n   179\\t**File:** `extensions/skillweaver/src/decomposer.ts`\\n   180\\t**Anchor:** `decompose()` method — add AbortSignal-based timeout support as an optional parameter. No Before/After change needed if the existing `try/catch` already handles fetch errors — verify it catches all HTTP error statuses and network failures.\\n   181\\t\\n   182\\tAdd optional `signal` parameter to `decompose()`:\\n   183\\t\\n   184\\t**Before:**\\n   185\\t```ts\\n   186\\t  async decompose(query: string, hints?: HintEntry[], maxSubTasks = 10): Promise<DecompositionResult> {\\n   187\\t```\\n   188\\t**After:**\\n   189\\t```ts\\n   190\\t  async decompose(query: string, hints?: HintEntry[], maxSubTasks = 10, signal?: AbortSignal): Promise<DecompositionResult> {\\n   191\\t```\\n   192\\tAnd wrap the fetch call in the try block:\\n   193\\t```ts\\n   194\\t      const response = await this.config.fetchRaw(endpoint, { method: \\\"POST\\\", headers, body, ...(signal ? { signal } : {}) });\\n   195\\t```\\n   196\\t\\n   197\\t## Allowed moves\\n   198\\t\\n   199\\tOnly modify the two files listed in `files:`. Add the new timeout test file. Do NOT change any other file.\\n   200\\t\\n   201\\t## STOP triggers\\n   202\\t\\n   203\\t- Error handler logs API keys\\n   204\\t- `cleanUserMessage` guard unintentionally blocks valid messages with `text: \\\"\\\"` that have other content\\n   205\\t- AbortSignal not passed through to fetch in decomposer\\n   206\\t\\n   207\\t## Done when\\n   208\\t\\n   209\\t`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx vitest run src/handler.test.ts src/decomposer.timeout.test.ts\\\" bash ~/.claude/wai/scripts/task-gate.sh plugin-skillweaver 015` exits 0     1\\t---\\n     2\\tid: \\\"016\\\"\\n     3\\tphase: 6\\n     4\\ttitle: Add lifecycle management — clean teardown on plugin unload, backend dispose, index dispose, watcher cleanup\\n     5\\tstatus: ready\\n     6\\tdepends_on: [\\\"014\\\"]\\n     7\\tparallel: false\\n     8\\tconflicts_with: []\\n     9\\tfiles:\\n    10\\t  - extensions/skillweaver/index.ts\\n    11\\tirreversible: false\\n    12\\tscope_test: \\\"extensions/skillweaver/index.test.ts\\\"\\n    13\\tallowed_change: edit\\n    14\\tcovers_criteria: [SC7]\\n    15\\t---\\n    16\\t## Failing test (write first)\\n    17\\t\\n    18\\tAdd these tests to `extensions/skillweaver/index.test.ts`:\\n    19\\t\\n    20\\t```ts\\n    21\\t  // ==== Add to existing describe(\\\"plugin register() wiring\\\", () => { ... }) block ====\\n    22\\t\\n    23\\t  it(\\\"handles duplicate register() calls without crash\\\", () => {\\n    24\\t    const api = createMockApi();\\n    25\\t    plugin.register(api);\\n    26\\t    expect(() => plugin.register(api)).not.toThrow();\\n    27\\t  });\\n    28\\t\\n    29\\t  it(\\\"does not register when embedding backend is missing\\\", () => {\\n    30\\t    const api = createMockApi({\\n    31\\t      pluginConfig: { embedding: { backend: \\\"custom\\\" } }, // custom requires endpoint\\n    32\\t    });\\n    33\\t    expect(() => plugin.register(api)).toThrow();\\n    34\\t  });\\n    35\\t\\n    36\\t  it(\\\"handles null pluginConfig gracefully\\\", () => {\\n    37\\t    const api = createMockApi({ pluginConfig: null as never });\\n    38\\t    expect(() => plugin.register(api)).not.toThrow();\\n    39\\t  });\\n    40\\t```\\n    41\\t\\n    42\\tAlso create `extensions/skillweaver/src/lifecycle.test.ts`:\\n    43\\t\\n    44\\t```ts\\n    45\\timport { describe, it, expect, vi, beforeEach } from \\\"vitest\\\";\\n    46\\timport type { EmbeddingBackend } from \\\"./embedding/types.js\\\";\\n    47\\t\\n    48\\tconst mockDispose = vi.fn();\\n    49\\tconst mockBackend: EmbeddingBackend = {\\n    50\\t  id: \\\"test\\\",\\n    51\\t  dimensions: 4,\\n    52\\t  embed: async (t: string[]) => t.map(() => new Float32Array(4)),\\n    53\\t  embedSingle: async () => new Float32Array(4),\\n    54\\t  dispose: mockDispose,\\n    55\\t};\\n    56\\t\\n    57\\tlet SkillIndex: { new (b: EmbeddingBackend): { build: Function; dispose: Function; getSkill: Function; watch: Function; unwatch: Function; size: number } };\\n    58\\tlet Decomposer: { new (...a: unknown[]): { dispose: Function } };\\n    59\\tlet LocalEmbedding: { new (...a: unknown[]): { id: string; dimensions: number; dispose: Function } };\\n    60\\tlet CloudEmbedding: { new (...a: unknown[]): { id: string; dimensions: number; dispose: Function } };\\n    61\\tlet CustomEmbedding: { new (...a: unknown[]): { id: string; dimensions: number; dispose: Function } };\\n    62\\t\\n    63\\tdescribe(\\\"lifecycle\\\", () => {\\n    64\\t  beforeAll(async () => {\\n    65\\t    SkillIndex = (await import(\\\"./skill-index.js\\\")).SkillIndex;\\n    66\\t    Decomposer = (await import(\\\"./decomposer.js\\\")).Decomposer;\\n    67\\t    LocalEmbedding = (await import(\\\"./embedding/local.js\\\")).LocalEmbedding;\\n    68\\t    CloudEmbedding = (await import(\\\"./embedding/cloud.js\\\")).CloudEmbedding;\\n    69\\t    CustomEmbedding = (await import(\\\"./embedding/custom.js\\\")).CustomEmbedding;\\n    70\\t  });\\n    71\\t\\n    72\\t  it(\\\"SkillIndex.dispose() clears skills and index\\\", async () => {\\n    73\\t    const index = new SkillIndex(mockBackend);\\n    74\\t    await index.build([\\n    75\\t      { name: \\\"test\\\", description: \\\"desc\\\", location: \\\"/x\\\", source: \\\"bundled\\\" },\\n    76\\t    ]);\\n    77\\t    expect(index.size).toBeGreaterThan(0);\\n    78\\t    index.dispose();\\n    79\\t    expect(index.size).toBe(0);\\n    80\\t  });\\n    81\\t\\n    82\\t  it(\\\"Decomposer.dispose() prevents further calls\\\", () => {\\n    83\\t    const d = new Decomposer({ provider: \\\"openrouter\\\", model: \\\"test\\\", apiKey: \\\"k\\\" });\\n    84\\t    d.dispose();\\n    85\\t    expect(() => d.dispose()).not.toThrow(); // idempotent\\n    86\\t  });\\n    87\\t\\n    88\\t  it(\\\"embedding backends support idempotent dispose\\\", () => {\\n    89\\t    const local = new LocalEmbedding();\\n    90\\t    const cloud = new CloudEmbedding();\\n    91\\t    const custom = new CustomEmbedding({ endpoint: \\\"http://localhost:8080/v1/embeddings\\\" });\\n    92\\t\\n    93\\t    expect(() => local.dispose()).not.toThrow();\\n    94\\t    expect(() => local.dispose()).not.toThrow(); // idempotent\\n    95\\t    expect(() => cloud.dispose()).not.toThrow();\\n    96\\t    expect(() => custom.dispose()).not.toThrow();\\n    97\\t  });\\n    98\\t\\n    99\\t  it(\\\"watch → unwatch → dispose cleans up completely\\\", async () => {\\n   100\\t    const backend: EmbeddingBackend = {\\n   101\\t      id: \\\"test\\\",\\n   102\\t      dimensions: 384,\\n   103\\t      embed: vi.fn().mockResolvedValue([new Float32Array(384)]),\\n   104\\t      embedSingle: vi.fn().mockResolvedValue(new Float32Array(384)),\\n   105\\t      dispose: vi.fn(),\\n   106\\t    };\\n   107\\t\\n   108\\t    const index = new SkillIndex(backend);\\n   109\\t    await index.build([\\n   110\\t      { name: \\\"github\\\", description: \\\"Git ops\\\", location: \\\"/x\\\", source: \\\"bundled\\\" },\\n   111\\t    ]);\\n   112\\t\\n   113\\t    expect(index.unwatch()).toBe(false); // no watcher active\\n   114\\t    index.dispose();\\n   115\\t    expect(index.size).toBe(0);\\n   116\\t  });\\n   117\\t});\\n   118\\t```\\n   119\\t\\n   120\\t## Change\\n   121\\t\\n   122\\t**File:** `extensions/skillweaver/index.ts`\\n   123\\t**Anchor:** add `api.on(\\\"agent_end\\\", ...)` cleanup handler inside `register()` — insert after the existing `api.on(\\\"context.collect\\\", handler)` line\\n   124\\t**Before:**\\n   125\\t```ts\\n   126\\t    api.on(\\\"context.collect\\\", handler);\\n   127\\t```\\n   128\\t**After:**\\n   129\\t```ts\\n   130\\t    api.on(\\\"context.collect\\\", handler);\\n   131\\t\\n   132\\t    api.on(\\\"agent_end\\\", async () => {\\n   133\\t      decomposer.dispose();\\n   134\\t      index.dispose();\\n   135\\t      await Promise.resolve(backend.dispose());\\n   136\\t    });\\n   137\\t```\\n   138\\t\\n   139\\t## Allowed moves\\n   140\\t\\n   141\\tOnly modify `extensions/skillweaver/index.ts` (add cleanup handler). Add the lifecycle test file. Do NOT create any new source files.\\n   142\\t\\n   143\\t## STOP triggers\\n   144\\t\\n   145\\t- `agent_end` handler throws uncaught error\\n   146\\t- `dispose()` called before components are initialized (guard with null check if needed)\\n   147\\t- Backend `dispose()` not awaited (may return `void | Promise<void>`)\\n   148\\t\\n   149\\t## Done when\\n   150\\t\\n   151\\t`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx vitest run index.test.ts src/lifecycle.test.ts\\\" bash ~/.claude/wai/scripts/task-gate.sh plugin-skillweaver 016` exits 0\",\"exit_code\":0,\"status\":\"completed\"}}\ndocs/plans/plugin-skillweaver/reviews/tournament-r1-codex.raw.log:47:{\"type\":\"item.started\",\"item\":{\"id\":\"item_25\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"rg -n \\\\\\\"discoverSkills|skillProvider|collectSkillPaths|sourceInfo|filePath|plugins/<plugin-id>|extensions/skillweaver|@wednesdayai/skillweaver|@wednesdayai-plugins|context.collect|source: \\\\\\\\\\\\\\\"skillweaver\\\\\\\\\\\\\\\"|source: \\\\\\\\\\\\\\\"plugin-skillweaver\\\\\\\\\\\\\\\"|JSON object|JSON array|subTasks|SC[1-7]|covers_criteria|irreversible|allowed_change|dependencies|@xenova|hnswlib\\\\\\\" docs/plans/plugin-skillweaver docs/superpowers/specs/2026-07-06-plugin-skillweaver.md README.md dev-docs/adr\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\ndocs/plans/plugin-skillweaver/reviews/tournament-r1-codex.raw.log:48:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_25\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"rg -n \\\\\\\"discoverSkills|skillProvider|collectSkillPaths|sourceInfo|filePath|plugins/<plugin-id>|extensions/skillweaver|@wednesdayai/skillweaver|@wednesdayai-plugins|context.collect|source: \\\\\\\\\\\\\\\"skillweaver\\\\\\\\\\\\\\\"|source: \\\\\\\\\\\\\\\"plugin-skillweaver\\\\\\\\\\\\\\\"|JSON object|JSON array|subTasks|SC[1-7]|covers_criteria|irreversible|allowed_change|dependencies|@xenova|hnswlib\\\\\\\" docs/plans/plugin-skillweaver docs/superpowers/specs/2026-07-06-plugin-skillweaver.md README.md dev-docs/adr\\\"\",\"aggregated_output\":\"README.md:18:Each plugin lives in `plugins/<plugin-id>/` with:\\nREADME.md:21:plugins/<plugin-id>/\\nREADME.md:22:  package.json       # name: @wednesdayai-plugins/<plugin-id>\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:23:This plugin brings SkillWeaver to WednesdayAI as a community extension, serving dual purpose: a production-grade skill router AND a reference implementation for the `context.collect` hook pattern.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:30:| **Plugin developers** | Reference implementation for `context.collect` + prompt contribution pattern. Demonstrates embedding infrastructure in an extension. |\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:37:US2: As a plugin developer, I want a reference implementation of the `context.collect` hook pattern for skill routing so I can build similar plugins without breaking system prompt caching.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:44:SC1: Retrieval accuracy — On a benchmark of 50 compositional queries against WednesdayAI's bundled skills, CatR@10 ≥ 65% (correct-category skill in top-10 candidates per sub-task). → US1:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:47:SC2: Decomposition accuracy — SAD decomposition produces correct step count (DA) on ≥ 60% of compositional queries (baseline: vanilla LLM decomposition ~45-50%). → US1:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:50:SC3: Context reduction — When active with `skills: \\\"names\\\"` config, the skills section of the system prompt ≤ 300 tokens (vs ~8K–15K in \\\"default\\\" mode). → US1:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:53:SC4: Cache safety — System prompt cache hit rate unchanged from baseline (skills injected as conversation context, not system prompt). → US1:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:56:SC5: Slash command survival — All existing skill slash commands (`/github`, `/weather`, etc.) continue functioning when plugin is active. → US1: US2:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:59:SC6: Pluggable embedding — Plugin works with at least three embedding backends: local (all-MiniLM-L6-v2 via @xenova/transformers), cloud (OpenAI text-embedding-3-small), custom (arbitrary OpenAI-compatible endpoint, e.g. Infinity in Docker). → US1: US3:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:62:SC7: Latency budget — End-to-end routing (decompose + retrieve + inject) adds ≤ 3s overhead to agent startup on typical hardware. Optional SAD decomposition pass adds ≤ 5s. → US1:\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:66:- **Extension only** — no core changes to WednesdayAI. Uses existing `context.collect` hook + `api.config`.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:85:The plugin injects retrieved skill descriptions into the **conversation** (not the system prompt) via the `context.collect` lifecycle hook — the same seam `memory-lancedb` uses for auto-recall. This preserves the system prompt's full cacheability while delivering query-relevant skill content exactly where the agent needs it: alongside the user's message.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:88:1. `context.collect` fires with the clean user message\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:98:- In-memory hnswlib index, never persisted to disk (rebuild is cheap at 56–200 skills)\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:117:│    │   └─ hnswlib index (in-memory)                  │\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:124:│  api.on(\\\"context.collect\\\", handler)                   │\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:135:context.collect event { cleanUserMessage, messages, envelope }\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:143:  │   └─ Embed sub-task → hnswlib NN search → [skill1, skill2, ...]\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:174:// Returned from context.collect handler\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:179:      source: \\\"plugin-skillweaver\\\",\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:195:        subTasks: [\\\"download CSV\\\", \\\"run analysis\\\"],\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:252:- `LocalEmbedding` — @xenova/transformers with all-MiniLM-L6-v2 (80MB, runs in-process)\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:260:### D1 — `context.collect` hook for injection (irreversible: contract)\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:262:**Choice:** Use `context.collect` hook to inject skill descriptions, not `before_prompt_build`.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:264:**Rationale:** `context.collect` returns `PromptContribution` with `prependContext` blocks, which land in the conversation portion — not the system prompt. This preserves the system prompt cache (Anthropic ephemeral, OpenAI `prompt_cache_key`). `before_prompt_build` returns a `systemPrompt` string that replaces the entire system prompt, which would vary per-query and destroy the cache hit for the full ~15K token system message.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:268:**ADR:** [ADR-0001](/dev-docs/adr/0001-context-collect-hook-for-skill-injection.md)\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:270:### D2 — Pluggable embedding backend (irreversible: interface contract)\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:274:**Rationale:** Users have diverse infrastructure. Some run everything locally (no API keys), some use cloud providers, some self-host embeddings via Infinity/Ollama in Docker. The interface is a thin abstraction — `embed(strings) → vectors` — that any backend can satisfy. The paper uses all-MiniLM-L6-v2 (384-dim), but higher-dimensional models (text-embedding-3-small: 1536-dim) may improve retrieval. The hnswlib index is dimension-agnostic.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:278:### D3 — SAD prompt contract (irreversible: decomposer protocol)\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:284:The prompt contract is: `{ subTasks: string[] }` — a JSON array of one-skill-per-task strings. This is intentionally minimal to keep parsing deterministic.\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:294:### D5 — In-memory hnswlib, no persistence\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:315:| `Decomposer` | Parse valid JSON response, handle malformed JSON, handle empty/missing subTasks field, Pass-1 no hints, Pass-2 with hints |\\ndocs/superpowers/specs/2026-07-06-plugin-skillweaver.md:327:| Hook registration | `context.collect` handler registered on `api.on()`, fires on agent run |\\ndev-docs/adr/0004-in-memory-index-no-persistence.md:52:Save and load the hnswlib index state. Rejected — complexity > benefit at current scale. Revisit when skill count exceeds ~1,000.\\ndev-docs/adr/0004-in-memory-index-no-persistence.md:55:Store the embedding vectors as JSON, rebuild hnswlib index from them on load. Similar complexity to full persistence. Rejected for same reason.\\ndev-docs/adr/0002-pluggable-embedding-backend-interface.md:35:1. **`local`** — `@xenova/transformers` with `all-MiniLM-L6-v2` (384-dim). Runs in-process, no network, 80MB model download on first use.\\ndev-docs/adr/0002-pluggable-embedding-backend-interface.md:47:The hnswlib index is dimension-agnostic — it stores vectors of whatever dimension the backend produces. This means switching from local (384-dim) to cloud (1536-dim) requires a full index rebuild (re-embed all skills), but no code changes. Config change + restart = new backend active.\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:5:title: \\\"ADR-0001: Use context.collect hook for skill injection\\\"\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:10:# ADR-0001: Use `context.collect` hook for skill injection\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:18:2. **`context.collect`** — returns a `PromptContribution` with `prependContext`, `appendContext`, `appendAfterUserMessage`, and other blocks that land in the *conversation* portion, not the system prompt.\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:22:Use `context.collect` hook for skill injection. Do not use `before_prompt_build`.\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:34:If we inject skill content into the conversation (via `context.collect`'s `prependContext`), the system prompt stays identical across requests → full cache hit. The conversation portion is dynamic anyway — adding 500–1500 tokens of skill descriptions has zero marginal caching penalty.\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:42:The `memory-lancedb` extension already uses this pattern: it reads the user message, searches a vector DB for relevant memories, and injects them as `prependContext` via `context.collect`. SkillWeaver follows the same architecture: search → inject as conversation context.\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:49:- **Negative:** The `context.collect` hook does not receive the final assembled system prompt — we can't inspect whether the user actually has `skills: \\\"names\\\"` set at runtime. We must check `api.config` at startup instead.\\ndev-docs/adr/0001-context-collect-hook-for-skill-injection.md:54:This returns `prependContext` (not `systemPrompt`), which also lands in conversation. But the hook signature bundles `systemPrompt` override capability, creating a footgun risk (future maintainer uses `systemPrompt` return, breaks caching). `context.collect` has no `systemPrompt` return — it's impossible to accidentally break caching.\\ndocs/plans/plugin-skillweaver/reviews/tournament-r1-opencode.raw.log:2:{\\\"type\\\":\\\"tool_use\\\",\\\"timestamp\\\":1783319145987,\\\"sessionID\\\":\\\"ses_0c9e55ffbffeHWPeybQMyaT1QL\\\",\\\"part\\\":{\\\"type\\\":\\\"tool\\\",\\\"tool\\\":\\\"read\\\",\\\"callID\\\":\\\"call_v7tli88m\\\",\\\"state\\\":{\\\"status\\\":\\\"error\\\",\\\"input\\\":{\\\"filePath\\\":\\\"/Users/david/Code/WednesdayAI-plugins/docs/plans/plugin-skillweaver/reviews/tournament-find.md\\\"},\\\"error\\\":\\\"The user rejected permission to use this specific tool call.\\\",\\\"time\\\":{\\\"start\\\":1783319145970,\\\"end\\\":1783319145985}},\\\"id\\\":\\\"prt_f361aaddf0019xSYmdhDG01pqP\\\",\\\"sessionID\\\":\\\"ses_0c9e55ffbffeHWPeybQMyaT1QL\\\",\\\"messageID\\\":\\\"msg_f361aa067002q80RMvDVNp1lqA\\\"}}\\ndocs/plans/plugin-skillweaver/reviews/tournament-r1-opencode.raw.log:3:{\\\"type\\\":\\\"tool_use\\\",\\\"timestamp\\\":1783319146087,\\\"sessionID\\\":\\\"ses_0c9e55ffbffeHWPeybQMyaT1QL\\\",\\\"part\\\":{\\\"type\\\":\\\"tool\\\",\\\"tool\\\":\\\"read\\\",\\\"callID\\\":\\\"call_r6g315c2\\\",\\\"state\\\":{\\\"status\\\":\\\"error\\\",\\\"input\\\":{\\\"filePath\\\":\\\"/Users/david/Code/WednesdayAI-plugins/docs/superpowers/specs/2026-07-06-plugin-skillweaver.md\\\"},\\\"error\\\":\\\"The user rejected permission to use this specific tool call.\\\",\\\"time\\\":{\\\"start\\\":1783319146079,\\\"end\\\":1783319146085}},\\\"id\\\":\\\"prt_f361aae5a001OBV2Bj447X317v\\\",\\\"sessionID\\\":\\\"ses_0c9e55ffbffeHWPeybQMyaT1QL\\\",\\\"messageID\\\":\\\"msg_f361aa067002q80RMvDVNp1lqA\\\"}}\\ndocs/plans/plugin-skillweaver/reviews/tournament-r1-opencode.raw.log:4:{\\\"type\\\":\\\"tool_use\\\",\\\"timestamp\\\":1783319146152,\\\"sessionID\\\":\\\"ses_0c9e55ffbffeHWPeybQMyaT1QL\\\",\\\"part\\\":{\\\"type\\\":\\\"tool\\\",\\\"tool\\\":\\\"read\\\",\\\"callID\\\":\\\"call_fy2aw9zu\\\",\\\"state\\\":{\\\"status\\\":\\\"error\\\",\\\"input\\\":{\\\"filePath\\\":\\\"/Users/david/Code/WednesdayAI-plugins/docs/plans/plugin-skillweaver/plan.md\\\"},\\\"error\\\":\\\"The user rejected permission to use this specific tool call.\\\",\\\"time\\\":{\\\"start\\\":1783319146149,\\\"end\\\":1783319146151}},\\\"id\\\":\\\"prt_f361aaea30017J66vIW1du2ZiU\\\",\\\"sessionID\\\":\\\"ses_0c9e55ffbffeHWPeybQMyaT1QL\\\",\\\"messageID\\\":\\\"msg_f361aa067002q80RMvDVNp1lqA\\\"}}\\ndev-docs/adr/0003-sad-prompt-contract.md:28:Output a JSON object with a \\\"subTasks\\\" array of strings.\\ndev-docs/adr/0003-sad-prompt-contract.md:33:Output format: { \\\"subTasks\\\": [\\\"task 1\\\", \\\"task 2\\\", ...] }\\ndev-docs/adr/0003-sad-prompt-contract.md:49:Output format: { \\\"subTasks\\\": [\\\"task 1\\\", \\\"task 2\\\", ...] }\\ndev-docs/adr/0003-sad-prompt-contract.md:55:{ \\\"subTasks\\\": [\\\"string\\\", \\\"string\\\", ...] }\\ndev-docs/adr/0003-sad-prompt-contract.md:58:Parsing: extract first JSON object from response → validate `subTasks` is an array of strings → max 10 sub-tasks → truncate if exceeded.\\ndev-docs/adr/0003-sad-prompt-contract.md:73:The decomposer must output pure JSON. Markdown code fences (` ```json ... ``` `) are stripped before parsing. This avoids the most common parsing failure mode (model wraps JSON in markdown). Any JSON object in the response is matched by regex — the first valid `{...}` wins.\\ndev-docs/adr/0003-sad-prompt-contract.md:77:Hints are formatted as human-readable bullet points, not a JSON array of skill objects. Rationale: the decomposer LLM is better at reading natural language than parsing nested JSON structures in a prompt. The format `- name: description` is compact (15 hints × ~75 chars = ~1,100 tokens) and readable.\\ndev-docs/adr/0003-sad-prompt-contract.md:97:- **Negative:** JSON parsing is fragile — a model that adds explanatory text before/after the JSON object may cause parse failures. The regex extraction (`/{[\\\\s\\\\S]*}/`) mitigates this but isn't perfect.\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:10:  - extensions/skillweaver/src/config.ts\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:11:irreversible: false\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:12:scope_test: \\\"extensions/skillweaver/src/config.test.ts\\\"\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:13:allowed_change: create\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:14:covers_criteria: [SC6]\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:18:Create `extensions/skillweaver/src/config.test.ts`:\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:91:**File:** `extensions/skillweaver/src/config.ts`\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:197:Create exactly `extensions/skillweaver/src/config.ts` and `extensions/skillweaver/src/config.test.ts`. No other files.\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:201:- `extensions/skillweaver/src/` directory missing (task 001 not completed)\\ndocs/plans/plugin-skillweaver/phase-1/002-config-schema.md:207:`WAI_TYPECHECK_CMD=\\\"cd extensions/skillweaver && pnpm exec tsc --noEmit\\\" WAI_TEST_CMD=\\\"cd extensions/skillweaver && npx vitest run src/config.test.ts\\\" bash ~/.claude/wai/scripts/task-gate.sh plugin-skillweaver 002` exits 0\\ndocs/plans/plugin-skillweaver/reviews/tournament-find.md:27:ADRs for irreversible decisions:\\ndocs/plans/plugin-skillweaver/reviews/tournament-find.md:28:dev-docs/adr/0001-plugin-skillweaver-context-collect.md\\ndocs/plans/plugin-skillweaver/reviews/tournament-find.md:36:1. Not bite-sized / two concerns in one task. 2. Wrong/non-existent anchor/symbol/Before-text (VERIFY against the repo — NOTE: this is a NEW extension, target files do NOT exist yet; verify that file paths and import specifiers are plausible for a wednesdayai/plugin-sdk extension). 3. Ambiguous instruction. 4. allowed_change mismatch. 5. Dependency/conflict error or cycle. 6. Unmarked irreversible. 7. Untestable or HOLLOW test (passes without the implementation). 8. CONTROL-FLOW GROUNDING: open the real extension code in extensions/diffs/ as reference; a plausible-but-inverted call path is a finding — symbol existence ≠ control-flow correctness. 9. Fidelity: an SC/TS clause no task truly delivers (covered-but-hollow); walk EACH clause sub-id (SC2a/SC2b…) to a task.\\ndocs/plans/plugin-skillweaver/phase-1/001-plugin-scaffold.md:10:  - extensions/skillweaver/package.json\\ndocs/plans/plugin-skillweaver/phase-1/001-plugin-scaffold.md:11:  - extensions/skillweaver/openclaw.plugin.json\\ndocs/plans/plugin-skillweaver/phase-1/001-plugin-scaffold.md:12:  - extensions/skillweaver/tsconfig.json\\ndocs/plans/plugin-skillweaver/phase-1/001-plugin-scaffold.md:13:irreversible: false\\ndocs/plans/plugin-skillweaver/phase-1/001-plugin-scaffold.md:14:scope_test: \\\"extensions/skillweaver\\\"\\ndocs/plans/plugin-skil