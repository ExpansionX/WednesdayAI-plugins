 => {},\\n    30\\t};\\n    31\\t\\n    32\\tconst sampleSkills: SkillEntry[] = [\\n    33\\t  { name: \\\"github\\\", description: \\\"Git operations via gh CLI\\\", location: \\\"/skills/github/SKILL.md\\\", source: \\\"bundled\\\" },\\n    34\\t  { name: \\\"weather\\\", description: \\\"Fetch weather data from APIs\\\", location: \\\"/skills/weather/SKILL.md\\\", source: \\\"bundled\\\" },\\n    35\\t  { name: \\\"slack\\\", description: \\\"Slack messaging and channel ops\\\", location: \\\"/skills/slack/SKILL.md\\\", source: \\\"bundled\\\" },\\n    36\\t  { name: \\\"duplicate\\\", description: \\\"Duplicate name, different source\\\", location: \\\"/skills/dup/SKILL.md\\\", source: \\\"managed\\\" },\\n    37\\t  { name: \\\"github\\\", description: \\\"Duplicate github from managed\\\", location: \\\"/other/github/SKILL.md\\\", source: \\\"managed\\\" },\\n    38\\t];\\n    39\\t\\n    40\\tlet SkillIndex: { new (...args: unknown[]): { build: Function; search: Function; getSkill: Function; size: number; dispose: Function } };\\n    41\\t\\n    42\\tdescribe(\\\"SkillIndex\\\", () => {\\n    43\\t  beforeAll(async () => {\\n    44\\t    const mod = await import(\\\"./skill-index.js\\\");\\n    45\\t    SkillIndex = mod.SkillIndex;\\n    46\\t  });\\n    47\\t\\n    48\\t  describe(\\\"build()\\\", () => {\\n    49\\t    it(\\\"builds index from skill entries\\\", async () => {\\n    50\\t      const index = new SkillIndex(mockBackend);\\n    51\\t      await index.build(sampleSkills);\\n    52\\t      expect(index.size).toBeGreaterThan(0);\\n    53\\t    });\\n    54\\t\\n    55\\t    it(\\\"deduplicates skills by name (last-loaded wins)\\\", async () => {\\n    56\\t      const index = new SkillIndex(mockBackend);\\n    57\\t      await index.build(sampleSkills);\\n    58\\t      const skill = index.getSkill(\\\"github\\\");\\n    59\\t      expect(skill?.source).toBe(\\\"managed\\\");\\n    60\\t      expect(skill?.location).toBe(\\\"/other/github/SKILL.md