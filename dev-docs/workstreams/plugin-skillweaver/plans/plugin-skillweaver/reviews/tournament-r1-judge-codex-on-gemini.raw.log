`\n   194\t**Anchor:** new file — create at this path\n   195\t**Before:** file does not exist\n   196\t**After:**\n   197\t```ts\n   198\timport type { DecompositionResult, HintEntry } from \"./embedding/types.js\";\n   199\t\n   200\texport interface DecomposerOptions {\n   201\t  fetchRaw?: typeof fetch;\n   202\t  provider: string;\n   203\t  model: string;\n   204\t  apiKey?: string | null;\n   205\t  baseUrl?: string | null;\n   206\t  temperature?: number;\n   207\t  maxTokens?: number;\n   208\t}\n   209\t\n   210\texport interface DecomposerConfig extends DecomposerOptions {\n   211\t  fetchRaw: typeof fetch;\n   212\t}\n   213\t\n   214\tfunction resolveEndpoint(provider: string, baseUrl?: string | null): string {\n   215\t  if (baseUrl) return baseUrl;\n   216\t  switch (provider) {\n   217\t    case \"openai\": return \"https://api.openai.com/v1/chat/completions\";\n   218\t    case \"anthropic\": return \"https://api.anthropic.com/v1/messages\";\n   219\t    case \"openai-compatible\": throw new Error(\"openai-compatible requires baseUrl\");\n   220\t    default: return \"https://openrouter.ai/api/v1/chat/completions\";\n   221\t  }\n   222\t}\n   223\t\n   224\tfunction buildSADPass1Prompt(query: string): string {\n   225\t  return `You are a query decomposition tool. Break the following user query into a list of atomic sub-tasks. Each sub-task should be a single, self-contained action that could be performed by a specific skill. Output ONLY a JSON array of strings.\n   226\t\n   227\tQuery: ${query}\n   228\t\n   229\tOutput:`;\n   230\t}\n   231\t\n   232\tfunction buildSADPass2Prompt(query: string, hints: string): string {\n   233\t  return `You are a query decomposition tool. Break the following user query into a list of atomic sub-tasks. Each sub-task should be mapped to ONE of the available skills listed below. Use the skill names in your sub-task descriptions to maximize retrievability.\n   234\t\n   235\tAvailable skills:\n   236\t${hints}\n   