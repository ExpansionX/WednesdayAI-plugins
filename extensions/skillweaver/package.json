{
  "name": "@wednesdayai/skillweaver",
  "version": "0.1.0",
  "private": true,
  "description": "SkillWeaver — compositional skill routing for WednesdayAI via context.collect hook",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
